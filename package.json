    "autoprefixer": "^10.4.0",
    "gray-matter": "^4.0.2",
    "image-size": "1.0.0",
    "next": "12.0.3",
    "next-mdx-remote": "^3.0.8",
    "next-seo": "4.28.1",
    "next-themes": "^0.0.15",
    "postcss": "^8.3.11",
